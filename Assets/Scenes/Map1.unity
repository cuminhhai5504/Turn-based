  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: c6fe86edf764bcf42ab2a8a6bf62f569, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::MapDialogue
  dialogueID: 1
  dialogueLines:
  - "V\u01B0\u01A1ng qu\u1ED1c n\xE0y \u0111ang d\u1EA7n th\u1ED1i n\xE1t, phe c\xE1nh
    \u1EE7ng h\u1ED9 ph\xE9p thu\u1EADt \u0111en \u0111ang d\u1EA7n chi\u1EBFm l\u1EA5y
    quy\u1EC1n ki\u1EC3m so\xE1t to\xE0n b\u1ED9 v\u01B0\u01A1ng qu\u1ED1c."
  - "C\xF3 l\u1EBD \u0111\xE2y l\xE0 l\xED do m\xE0 cha ta, vua c\u1EE7a v\u01B0\u01A1ng
    qu\u1ED1c b\xED m\u1EADt \u0111\u01B0a ta r\u1EDDi kh\u1ECFi qu\u1ED1c \u0111\xF4."
  - "Gi\u1EDD \u0111\xE2y ch\xFAng \u0111ang \u0111\u01B0a nh\u1EEFng v\u1EADt tri\u1EC7u
    h\u1ED3i t\u1EEB ph\xE1p thu\u1EADt \u0111en \u0111\xF3 \u0111\u1EBFn qu\u1EA5y
    ph\xE1 l\xE0ng qu\xEA y\xEAn b\xECnh c\u1EE7a ta."
  - "Ta kh\xF4ng th\u1EC3 s\u1ED1ng h\xE8n nh\xE1t nh\u01B0 v\u1EADy c\u1EA3 \u0111\u1EDDi
    \u0111\u01B0\u1EE3c, h\u1EE1i nh\u1EEFng ng\u01B0\u1EDDi chi\u1EBFn s\u0129 tr\u1EBB
    tu\u1ED5i, h\xE3y gi\xFAp ta quay tr\u1EDF v\u1EC1"
