  m_Script: {fileID: 11500000, guid: c6fe86edf764bcf42ab2a8a6bf62f569, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::MapDialogue
  dialogueID: 6
  dialogueLines:
  - "-B\u1EA1n-Con \u0111\xE3 quay l\u1EA1i r\u1ED3i th\u01B0a cha"
  - "-Qu\u1ED1c v\u01B0\u01A1ng-Sao con l\u1EA1i v\u1EC1 \u0111\xE2y, huy\u1EBFt
    m\u1EA1ch c\u1EE7a ta c\u1EA7n \u0111\u01B0\u1EE3c k\xE9o d\xE0i"
  - "-B\u1EA1n-H\xE3y tin \u1EDF con v\xE0 nh\u1EEFng v\u1ECB anh h\xF9ng n\xE0y,
    ...t\u1EA5t c\u1EA3 h\u1ED9 gi\xE1!!!"
  - "-Ph\xE1p su c\u1EA5m ch\xFA-Haha, n\u1EBFu \u0111\u1EE9a con ngu ng\u1ED1c c\u1EE7a
    ng\u01B0\u1EDDi \u0111\xE3 ch\u1ECDn v\u1EADy th\xEC h\xE3y c\xF9ng nhau xu\u1ED1ng
    ho\xE0ng tuy\u1EC1n \u0111i"
  - "-B\u1EA1n-Ng\u01B0\u01A1i h\xE3y t\u1EF1 xu\u1ED1ng d\u01B0\u1EDBi \u0111\xF3
    m\xE0 \u0111o\xE0n t\u1EE5 v\u1EDBi nh\u1EEFng t\xEAn ta \u0111\xE3 \u0111\xE1nh
    b\u1EA1i "
